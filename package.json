{
  "name": "little-lnd-checklist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://checklist.littlelnd.com",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "validate-content": "node scripts/validate-content.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run validate-content && npm run typecheck",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -b gh-pages -m \"deploy: $(date -u +%Y-%m-%dT%H:%M:%SZ)\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.2.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
